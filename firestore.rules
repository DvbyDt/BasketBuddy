rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Users (multi-tenant) ────────────────────────────────────
    // All user-generated data is scoped to the authenticated user.
    //
    // Data model:
    //   users/{uid}/customItems/{itemId}
    //   users/{uid}/basket/{basketItemId}
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // user root doc not used (subcollections only)

      match /customItems/{itemId} {
        allow read, list: if request.auth != null && request.auth.uid == uid;
        allow create: if request.auth != null
                      && request.auth.uid == uid
                      && request.resource.data.createdBy == request.auth.uid;
        allow update, delete: if request.auth != null
                              && request.auth.uid == uid
                              && resource.data.createdBy == request.auth.uid;
      }

      match /basket/{basketItemId} {
        allow read, list: if request.auth != null && request.auth.uid == uid;
        allow create: if request.auth != null
                      && request.auth.uid == uid
                      && request.resource.data.addedBy == request.auth.uid;
        allow update, delete: if request.auth != null
                              && request.auth.uid == uid
                              && resource.data.addedBy == request.auth.uid;
      }
    }

    // ─── Deny everything else ────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
