{
  "name": "basketbuddy-functions",
  "private": true,
  "main": "lib/index.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "npx tsc -p tsconfig.json",
    "build:watch": "npx tsc -p tsconfig.json --watch",
